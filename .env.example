# Next na 3000 + API no host: matriculas-react/.env com MATRICULAS_API_ORIGIN=http://127.0.0.1:3001
# Postgres só no Docker: DB_HOST=127.0.0.1 e DB_PORT igual ao mapeamento do compose (${DB_PORT}:5432).
# Não use DB_HOST=db fora do container da API — cada GET /api/* pode ficar ~20s e voltar 500.
